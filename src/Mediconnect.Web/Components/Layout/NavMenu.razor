<AuthorizeView>
    <Authorized>
        <NavLink class="app-nav-link" href="" Match="NavLinkMatch.All" @onclick="Notify">Trang chủ</NavLink>

        <NavLink class="app-nav-link" href="beds" @onclick="Notify">F1 · Giường</NavLink>
        <NavLink class="app-nav-link" href="vitals" @onclick="Notify">F2 · Y lệnh</NavLink>
        <NavLink class="app-nav-link" href="lab" @onclick="Notify">F3 · Cận lâm sàng</NavLink>
        <NavLink class="app-nav-link" href="discharge" @onclick="Notify">F4 · Xuất viện</NavLink>
        <NavLink class="app-nav-link" href="schedules" @onclick="Notify">Lịch trực</NavLink>

        <AuthorizeView Roles="Doctor,Nurse,Admin" Context="clinicalCtx">
            <Authorized>
                <NavLink class="app-nav-link" href="clinic-dashboard" @onclick="Notify">Hàng đợi phòng khám</NavLink>
                <NavLink class="app-nav-link" href="outpatient-record" @onclick="Notify">Hồ sơ ngoại trú</NavLink>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="Doctor,Nurse" Context="prescriptionCtx">
            <Authorized>
                <NavLink class="app-nav-link" href="e-prescription" @onclick="Notify">Đơn thuốc điện tử</NavLink>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="Patient" Context="patientCtx">
            <Authorized>
                <NavLink class="app-nav-link" href="booking" @onclick="Notify">Đặt lịch khám</NavLink>
                <NavLink class="app-nav-link" href="appointments" @onclick="Notify">Lịch hẹn của tôi</NavLink>
                <NavLink class="app-nav-link" href="billing" @onclick="Notify">Viện phí</NavLink>
                <NavLink class="app-nav-link" href="health-records" @onclick="Notify">Hồ sơ sức khỏe</NavLink>
                <NavLink class="app-nav-link" href="my-reviews" @onclick="Notify">Đánh giá</NavLink>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="Admin" Context="adminCtx">
            <Authorized>
                <NavLink class="app-nav-link" href="manage-services" @onclick="Notify">Dịch vụ</NavLink>
                <NavLink class="app-nav-link" href="admin/staff" @onclick="Notify">Nhân sự</NavLink>
                <NavLink class="app-nav-link" href="admin/users" @onclick="Notify">Tài khoản</NavLink>
                <NavLink class="app-nav-link" href="admin/drug-interactions" @onclick="Notify">Tương tác thuốc</NavLink>
                <NavLink class="app-nav-link" href="admin/otp-security" @onclick="Notify">OTP & Bảo mật</NavLink>
                <NavLink class="app-nav-link" href="reports/revenue" @onclick="Notify">Doanh thu</NavLink>
                <NavLink class="app-nav-link" href="reports/operations" @onclick="Notify">Vận hành</NavLink>
            </Authorized>
        </AuthorizeView>
    </Authorized>
</AuthorizeView>

@code {
    [Parameter] public EventCallback OnNavigate { get; set; }

    private Task Notify() => OnNavigate.HasDelegate ? OnNavigate.InvokeAsync() : Task.CompletedTask;
}
