@inherits LayoutComponentBase

<header class="app-header">
    <div class="app-header-inner">
        <a href="/" class="app-brand">
            <span class="material-symbols-outlined" style="font-size:1.7rem">local_hospital</span>
            MediConnect
        </a>

        <nav class="app-nav">
            <NavMenu />
        </nav>

        <div class="app-header-actions">
            <AuthorizeView>
                <Authorized>
                    <span class="app-user-chip">
                        <span class="material-symbols-outlined" style="font-size:.95rem">person</span>
                        @context.User.Identity?.Name
                    </span>
                    <button class="app-logout-btn" @onclick="Logout">Đăng xuất</button>
                </Authorized>
                <NotAuthorized>
                    <a href="login" class="app-nav-link">Đăng nhập</a>
                    <a href="register" class="btn btn-primary btn-pill btn-sm">Đăng ký</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <button class="app-mobile-toggle" @onclick="ToggleMobileMenu" aria-label="Menu">
            <span class="material-symbols-outlined">@(_mobileOpen ? "close" : "menu")</span>
        </button>
    </div>

    @if (_mobileOpen)
    {
        <div class="app-mobile-menu">
            <NavMenu OnNavigate="CloseMobileMenu" />

            <div class="app-mobile-menu-actions">
                <AuthorizeView>
                    <Authorized>
                        <span class="app-user-chip" style="align-self:flex-start">
                            <span class="material-symbols-outlined" style="font-size:.95rem">person</span>
                            @context.User.Identity?.Name
                        </span>
                        <button class="app-logout-btn" style="text-align:left" @onclick="Logout">Đăng xuất</button>
                    </Authorized>
                    <NotAuthorized>
                        <a href="login" class="app-nav-link" @onclick="CloseMobileMenu">Đăng nhập</a>
                        <a href="register" class="app-nav-link" @onclick="CloseMobileMenu">Đăng ký</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    }
</header>

<main class="app-main">
    @Body
</main>

<div id="blazor-error-ui">
    Đã xảy ra lỗi.
    <a href="" class="reload">Tải lại</a>
    <span class="dismiss">✕</span>
</div>

@code {
    [Inject] private ApiClient Api { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private bool _mobileOpen;

    private void ToggleMobileMenu() => _mobileOpen = !_mobileOpen;
    private void CloseMobileMenu() => _mobileOpen = false;

    private async Task Logout()
    {
        await Api.Logout();
        Nav.NavigateTo("/login");
    }
}
