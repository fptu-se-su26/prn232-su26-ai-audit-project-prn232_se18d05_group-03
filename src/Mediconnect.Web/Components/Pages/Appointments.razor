@page "/appointments"
@attribute [Authorize(Roles = "Patient")]

<PageTitle>Lịch hẹn của tôi – MediConnect</PageTitle>

<div style="max-width:720px;margin:0 auto">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0">Lịch hẹn của tôi</h4>
        <a class="btn btn-primary btn-pill btn-sm d-inline-flex align-items-center gap-1" href="/booking">
            <span class="material-symbols-outlined" style="font-size:1.1rem">add</span> Đặt lịch mới
        </a>
    </div>

    @if (_loading)
    {
        <div class="d-flex justify-content-center py-5">
            <span class="material-symbols-outlined spin" style="font-size:2.5rem;color:var(--color-primary)">progress_activity</span>
        </div>
    }
    else if (_appointments.Count == 0)
    {
        <div class="text-center py-5">
            <span class="material-symbols-outlined d-block mb-3" style="font-size:3.5rem;color:var(--color-outline-variant)">event_busy</span>
            <h5 class="mb-2">Chưa có lịch hẹn nào</h5>
            <p class="text-muted mb-4">Bạn chưa có lịch hẹn nào. Hãy đặt lịch khám ngay!</p>
            <a class="btn btn-primary btn-pill" href="/booking">Đặt lịch khám</a>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var a in _appointments)
            {
                <div class="card">
                    <div class="card-body d-flex justify-content-between align-items-start gap-3">
                        <div class="d-flex align-items-start gap-3">
                            <div class="d-flex align-items-center justify-content-center rounded-3 flex-shrink-0"
                                 style="width:48px;height:48px;background:var(--color-primary-container)">
                                <span class="material-symbols-outlined" style="color:var(--color-on-primary-container)">calendar_month</span>
                            </div>
                            <div>
                                <div style="font-weight:600">@a.AppointmentTime.ToString("dddd, dd/MM/yyyy HH:mm")</div>
                                @if (!string.IsNullOrWhiteSpace(a.Reason))
                                {
                                    <div class="text-muted mt-1" style="font-size:.82rem">@a.Reason</div>
                                }
                            </div>
                        </div>
                        <span class="badge @StatusBadge(a.Status) d-inline-flex align-items-center gap-1 flex-shrink-0">
                            <span class="material-symbols-outlined" style="font-size:.9rem">@StatusIcon(a.Status)</span>
                            @StatusLabel(a.Status)
                        </span>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Inject] private ApiClient Api { get; set; } = default!;

    private List<AppointmentReadDto> _appointments = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var profile = await Api.GetMyPatient();
            var all = (await Api.GetAppointments()) ?? new();
            _appointments = profile is null
                ? new()
                : all.Where(a => a.PatientId == profile.Id)
                     .OrderByDescending(a => a.AppointmentTime)
                     .ToList();
        }
        catch (ApiClient.ApiException) { /* treated as empty, matches original behavior */ }
        finally { _loading = false; }
    }

    private static string StatusLabel(AppointmentStatus s) => s switch
    {
        AppointmentStatus.Requested => "Chờ xác nhận",
        AppointmentStatus.Confirmed => "Đã xác nhận",
        AppointmentStatus.CheckedIn => "Đã check-in",
        AppointmentStatus.Completed => "Hoàn thành",
        AppointmentStatus.Cancelled => "Đã huỷ",
        _ => s.ToString()
    };

    private static string StatusBadge(AppointmentStatus s) => s switch
    {
        AppointmentStatus.Requested => "badge-soft-yellow",
        AppointmentStatus.Confirmed => "badge-soft-blue",
        AppointmentStatus.CheckedIn => "badge-soft-purple",
        AppointmentStatus.Completed => "badge-soft-green",
        AppointmentStatus.Cancelled => "badge-soft-red",
        _ => "badge-soft-red"
    };

    private static string StatusIcon(AppointmentStatus s) => s switch
    {
        AppointmentStatus.Requested => "hourglass_empty",
        AppointmentStatus.Confirmed => "check_circle",
        AppointmentStatus.CheckedIn => "how_to_reg",
        AppointmentStatus.Completed => "task_alt",
        AppointmentStatus.Cancelled => "cancel",
        _ => "help"
    };
}
