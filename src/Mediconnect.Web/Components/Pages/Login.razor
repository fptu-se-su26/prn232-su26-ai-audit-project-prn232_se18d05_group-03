@page "/login"
@attribute [AllowAnonymous]

<PageTitle>Đăng nhập – MediConnect</PageTitle>

<div class="login-wrap">
    <div class="login-brand">
        <span class="material-symbols-outlined" style="font-size:3rem;color:#60a5fa">local_hospital</span>
        <h2 class="mt-3 mb-1" style="color:#fff;font-weight:700">MediConnect</h2>
        <p style="color:rgba(255,255,255,.6);font-size:.85rem">Smart Hospital Information System</p>
        <div class="login-hint mt-4">
            <div style="font-size:.75rem;color:rgba(255,255,255,.5);margin-bottom:.5rem">Tài khoản demo</div>
            @foreach (var a in new[]{ ("admin@mediconnect.local","Admin@123","Admin"), ("doctor@mediconnect.local","Doctor@123","Doctor"), ("nurse@mediconnect.local","Nurse@123","Nurse"), ("lab@mediconnect.local","Lab@123","Lab") })
            {
                <div style="font-size:.72rem;color:rgba(255,255,255,.45);line-height:1.8">
                    <span style="color:rgba(255,255,255,.7)">@a.Item3:</span> @a.Item1 / @a.Item2
                </div>
            }
        </div>
    </div>

    <div class="login-card">
        <div class="login-card-inner">
            <h4 class="mb-1" style="font-weight:700">Đăng nhập</h4>
            <p class="text-muted mb-4" style="font-size:.82rem">Nhập thông tin tài khoản để tiếp tục</p>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger py-2 mb-3" style="font-size:.82rem">@_error</div>
            }

            <EditForm Model="_model" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <div class="input-group">
                        <span class="input-group-text" style="background:var(--surface);border-color:var(--border)">
                            <span class="material-symbols-outlined" style="font-size:1rem;color:var(--text-muted)">mail</span>
                        </span>
                        <InputText class="form-control" @bind-Value="_model.Email" placeholder="email@mediconnect.local" />
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label">Mật khẩu</label>
                    <div class="input-group">
                        <span class="input-group-text" style="background:var(--surface);border-color:var(--border)">
                            <span class="material-symbols-outlined" style="font-size:1rem;color:var(--text-muted)">lock</span>
                        </span>
                        <InputText type="password" class="form-control" @bind-Value="_model.Password" />
                    </div>
                </div>
                <button type="submit" class="btn btn-primary w-100" style="height:42px;font-size:.9rem" disabled="@_loading">
                    @if (_loading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    @(_loading ? "Đang đăng nhập..." : "Đăng nhập")
                </button>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [Inject] private ApiClient Api { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private LoginModel _model = new();
    private string? _error;
    private bool _loading;

    private async Task HandleLogin()
    {
        _loading = true; _error = null;
        try { await Api.LoginAsync(_model.Email, _model.Password); Nav.NavigateTo("/", forceLoad: false); }
        catch (ApiClient.ApiException ex) { _error = ex.Message; }
        catch { _error = "Không thể kết nối đến máy chủ."; }
        finally { _loading = false; }
    }

    private class LoginModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
