@page "/login"
@attribute [AllowAnonymous]

<PageTitle>Đăng nhập – MediConnect</PageTitle>

<div class="login-wrap">
    <div class="login-card">
        <div class="text-center mb-4">
            <span class="material-symbols-outlined" style="font-size:3rem;color:var(--color-primary)">local_hospital</span>
            <h4 class="mt-3 mb-1">Đăng nhập</h4>
            <p class="text-muted mb-0" style="font-size:.85rem">Nhập thông tin tài khoản để tiếp tục</p>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger py-2 mb-3" style="font-size:.82rem">@_error</div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />
            <div class="mb-3">
                <label class="form-label">Email</label>
                <InputText class="form-control" @bind-Value="_model.Email" placeholder="email@mediconnect.local" />
            </div>
            <div class="mb-4">
                <label class="form-label">Mật khẩu</label>
                <InputText type="password" class="form-control" @bind-Value="_model.Password" />
            </div>
            <button type="submit" class="btn btn-primary btn-pill w-100" style="height:44px;font-size:.9rem" disabled="@_loading">
                @if (_loading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                @(_loading ? "Đang đăng nhập..." : "Đăng nhập")
            </button>

            <p class="text-center text-muted mt-4 mb-0" style="font-size:.85rem">
                Chưa có tài khoản?
                <a href="register" style="font-weight:600">Đăng ký</a>
            </p>
        </EditForm>

        <div class="login-hint mt-4">
            <div class="text-muted mb-2" style="font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.04em">Tài khoản demo</div>
            @foreach (var a in new[]{ ("admin@mediconnect.local","Admin@123","Admin"), ("doctor@mediconnect.local","Doctor@123","Doctor"), ("nurse@mediconnect.local","Nurse@123","Nurse"), ("lab@mediconnect.local","Lab@123","Lab") })
            {
                <div style="font-size:.72rem;color:var(--color-on-surface-variant);line-height:1.8">
                    <span style="font-weight:600;color:var(--color-on-surface)">@a.Item3:</span> @a.Item1 / @a.Item2
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Inject] private ApiClient Api { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private LoginModel _model = new();
    private string? _error;
    private bool _loading;

    private async Task HandleLogin()
    {
        _loading = true; _error = null;
        try { await Api.LoginAsync(_model.Email, _model.Password); Nav.NavigateTo("/", forceLoad: false); }
        catch (ApiClient.ApiException ex) { _error = ex.Message; }
        catch { _error = "Không thể kết nối đến máy chủ."; }
        finally { _loading = false; }
    }

    private class LoginModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
