    private static (double left, double width) BarStyle(TimeOnly start, TimeOnly end)
    {
        var startMin = start.Hour * 60 + start.Minute;
        var endMin = end.Hour * 60 + end.Minute;
        if (endMin == 0 || endMin < startMin) endMin = 1440;
        return (startMin / 1440.0 * 100, (endMin - startMin) / 1440.0 * 100);
    }

    private static string Fmt(double v) => v.ToString(CultureInfo.InvariantCulture);
